<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:paddingHorizontal="@dimen/space_md"
    android:paddingVertical="@dimen/space_sm">

    <View
        android:id="@+id/timeline_line"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/color_primary"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/timeline_bullet"
        app:layout_constraintStart_toStartOf="@id/timeline_bullet"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/timeline_bullet"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginStart="@dimen/space_xs"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_timeline_bullet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layout_step_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:background="@color/color_surface"
        android:orientation="vertical"
        android:padding="@dimen/card_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/timeline_bullet"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_step_title"
                style="@style/TextAppearance.UpAgain.H3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@id/btn_step_edit"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/color_on_surface"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Step 1: Preparing Foundation Layout Setup" />

            <TextView
                android:id="@+id/tv_step_date"
                style="@style/TextAppearance.UpAgain.BodySmall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/color_secondary"
                app:layout_constraintEnd_toEndOf="@id/tv_step_title"
                app:layout_constraintStart_toStartOf="@id/tv_step_title"
                app:layout_constraintTop_toBottomOf="@id/tv_step_title"
                tools:text="Updated June 15, 2026" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_step_edit"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/min_touch"
                android:layout_height="@dimen/min_touch"
                app:icon="@drawable/ic_edit"
                app:iconSize="@dimen/icon_sm"
                app:iconTint="@color/color_accent"
                app:layout_constraintEnd_toStartOf="@id/btn_step_delete"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_step_delete"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/min_touch"
                android:layout_height="@dimen/min_touch"
                app:icon="@drawable/ic_trash"
                app:iconSize="@dimen/icon_sm"
                app:iconTint="@color/red"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_step_description"
            style="@style/TextAppearance.UpAgain.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:lineSpacingMultiplier="1.1"
            android:textColor="@color/color_on_background"
            tools:text="Mix compound parts slowly over five minutes to ensure uniform alignment parameters before joining frames." />

        <FrameLayout
            android:id="@+id/layout_step_carousel_wrapper"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="@dimen/space_md"
            android:background="@color/color_background"
            android:visibility="visible">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_step_carousel"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tl_step_carousel_indicator"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="@dimen/space_xs"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/tl_dot_indicator_selector"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="16dp"
                app:tabMinWidth="0dp"
                app:tabPaddingEnd="3dp"
                app:tabPaddingStart="3dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_label_materials"
            style="@style/TextAppearance.UpAgain.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/items_used"
            android:textColor="@color/color_secondary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_step_materials_list"
            style="@style/TextAppearance.UpAgain.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:lineSpacingMultiplier="1.2"
            android:textColor="@color/color_primary"
            tools:text="• Epoxy Resin Adhesive\n• 12mm Carbon Fiber Rails\n• Structural Clamps" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>