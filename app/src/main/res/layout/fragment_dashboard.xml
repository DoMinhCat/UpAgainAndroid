<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_background"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_lg">

            <TextView
                style="@style/TextAppearance.UpAgain.H1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                app:checkedButton="@+id/btn_7d"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_24h"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="24h"
                    android:textColor="@color/color_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_7d"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="7d"
                    app:backgroundTint="@color/color_primary"
                    android:textColor="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_30d"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="30d"
                    android:textColor="@color/color_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_year"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Year"
                    android:textColor="@color/color_secondary" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_xxl"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <!-- 1. Inventory Summary Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="@dimen/card_radius"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            style="@style/TextAppearance.UpAgain.H3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/inventory_summary"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_container"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/color_outline" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Pie Chart on Left, Legend on Right -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xl"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Mock Pie Chart -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            app:cardCornerRadius="60dp"
                            app:cardBackgroundColor="@color/color_primary"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            android:alpha="0.2" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_lg"
                            android:orientation="vertical">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Wood (45%)" android:textColor="#7A5C3E" android:paddingVertical="1dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Metal (15%)" android:textColor="#8E8E8E" android:paddingVertical="1dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Textile (10%)" android:textColor="@color/color_primary" android:paddingVertical="1dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Glass (10%)" android:textColor="#4A90E2" android:paddingVertical="1dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Plastic (10%)" android:textColor="@color/color_accent" android:paddingVertical="1dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Mixed (5%)" android:textColor="@color/color_on_background" android:paddingVertical="1dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="● Other (5%)" android:textColor="@color/color_outline" android:paddingVertical="1dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginVertical="@dimen/space_xl" />

                    <!-- Bar Chart Area (7 double columns) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:baselineAligned="false"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:weightSum="7">

                        <!-- Material Columns -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="80dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="50dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="60dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="70dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="40dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="30dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="90dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="40dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="55dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="25dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="30dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="45dp" android:background="#E0E0E0" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                            <View android:layout_width="6dp" android:layout_height="20dp" android:background="@color/color_primary" android:layout_marginEnd="2dp" />
                            <View android:layout_width="6dp" android:layout_height="15dp" android:background="#E0E0E0" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bar Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal"
                        android:weightSum="7">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_wood" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_metal" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_textile" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_glass" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_plastic" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_mixed" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/material_other" android:gravity="center" style="@style/TextAppearance.UpAgain.BodySmall" android:alpha="0.6" />
                    </LinearLayout>

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:layout_gravity="center"
                        android:orientation="horizontal">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@color/color_primary" android:layout_gravity="center_vertical" />
                        <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stock" android:layout_marginStart="4dp" android:alpha="0.6" />
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#E0E0E0" android:layout_gravity="center_vertical" android:layout_marginStart="@dimen/space_lg" />
                        <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/sold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:alpha="0.6" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Financial Overview Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="@dimen/card_radius"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView style="@style/TextAppearance.UpAgain.H3" android:text="@string/financial_overview" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
                        <ImageView android:layout_width="@dimen/icon_md" android:layout_height="@dimen/icon_md" android:src="@drawable/ic_dashboard" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/color_outline"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- 4 Financial Metric Cards with MaterialCardView -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:columnCount="2"
                        android:rowCount="2">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="#F9F7F2"
                            app:cardCornerRadius="@dimen/input_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_md">
                                <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/total_spent" android:alpha="0.5" android:maxLines="1" android:ellipsize="end" />
                                <TextView style="@style/TextAppearance.UpAgain.H2" android:text="$1.2k" android:layout_width="match_parent" android:layout_height="wrap_content" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="#F9F7F2"
                            app:cardCornerRadius="@dimen/input_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_md">
                                <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/items_bought" android:alpha="0.5" android:maxLines="1" android:ellipsize="end" />
                                <TextView style="@style/TextAppearance.UpAgain.H2" android:text="42" android:layout_width="match_parent" android:layout_height="wrap_content" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="#F9F7F2"
                            app:cardCornerRadius="@dimen/input_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_md">
                                <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/event_fees" android:alpha="0.5" android:maxLines="1" android:ellipsize="end" />
                                <TextView style="@style/TextAppearance.UpAgain.H2" android:text="$150" android:layout_width="match_parent" android:layout_height="wrap_content" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_columnWeight="1"
                            app:cardBackgroundColor="#F9F7F2"
                            app:cardCornerRadius="@dimen/input_radius"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/space_md">
                                <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/total_projects" android:alpha="0.5" android:maxLines="1" android:ellipsize="end" />
                                <TextView style="@style/TextAppearance.UpAgain.H2" android:text="12" android:layout_width="match_parent" android:layout_height="wrap_content" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>

                    <!-- 3. Spending by Material Title -->
                    <TextView
                        style="@style/TextAppearance.UpAgain.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xl"
                        android:text="@string/spending_by_material" />

                    <!-- 4. Material spending indicators -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/space_md">

                        <!-- Row Template: Name (Left, 100dp) | Indicator (Middle, weight 1) | Amount (Right, end aligned) -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_wood" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="80" app:indicatorColor="#7A5C3E" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$840" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_metal" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="40" app:indicatorColor="#8E8E8E" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$320" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_textile" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="30" app:indicatorColor="@color/color_primary" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$120" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_glass" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="20" app:indicatorColor="#4A90E2" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$80" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_plastic" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="15" app:indicatorColor="@color/color_accent" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$45" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_mixed" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="10" app:indicatorColor="@color/color_on_background" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$30" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="@dimen/space_sm">
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="@string/material_other" android:layout_width="100dp" android:maxLines="1" android:ellipsize="end" />
                            <com.google.android.material.progressindicator.LinearProgressIndicator android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:progress="5" app:indicatorColor="@color/color_outline" app:trackColor="#F0F0F0" app:trackCornerRadius="4dp" />
                            <TextView style="@style/TextAppearance.UpAgain.BodySmall" android:text="$15" android:layout_marginStart="@dimen/space_md" android:textStyle="bold" android:minWidth="80dp" android:gravity="end" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
