<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/space_sm"
    android:background="?attr/selectableItemBackground">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_cmt_avatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@tools:sample/avatars" />

    <TextView
        android:id="@+id/tv_cmt_user_name"
        style="@style/TextAppearance.UpAgain.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:textStyle="bold"
        android:textColor="@color/color_on_background"
        app:layout_constraintStart_toEndOf="@id/iv_cmt_avatar"
        app:layout_constraintTop_toTopOf="@id/iv_cmt_avatar"
        tools:text="Jack Collins" />

    <TextView
        android:id="@+id/tv_cmt_time"
        style="@style/TextAppearance.UpAgain.BodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_sm"
        android:textColor="@color/color_secondary"
        app:layout_constraintStart_toEndOf="@id/tv_cmt_user_name"
        app:layout_constraintBottom_toBottomOf="@id/tv_cmt_user_name"
        tools:text="12:23:56 - June 4 2026" />

    <TextView
        android:id="@+id/tv_cmt_content"
        style="@style/TextAppearance.UpAgain.BodyMedium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/color_on_background"
        app:layout_constraintStart_toStartOf="@id/tv_cmt_user_name"
        app:layout_constraintEnd_toStartOf="@id/layout_cmt_like_group"
        app:layout_constraintTop_toBottomOf="@id/tv_cmt_user_name"
        tools:text="This is an awesome analysis! Thanks for breaking down the architectural models." />

    <LinearLayout
        android:id="@+id/layout_cmt_like_group"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_cmt_like"
            android:layout_width="@dimen/icon_sm"
            android:layout_height="@dimen/icon_sm"
            android:layout_marginTop="@dimen/space_xs"
            android:src="@drawable/ic_love_outline"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/red" />

        <TextView
            android:id="@+id/tv_cmt_like_nb"
            style="@style/TextAppearance.UpAgain.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/color_secondary"
            tools:text="14" />
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_outline"
        android:alpha="0.15"
        android:layout_marginTop="@dimen/space_sm"
        app:layout_constraintTop_toBottomOf="@id/tv_cmt_content"
        app:layout_constraintStart_toStartOf="@id/tv_cmt_content"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>