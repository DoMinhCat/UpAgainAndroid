<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/space_sm"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:id="@+id/layout_comment_row_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="top">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_cmt_avatar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                tools:src="@tools:sample/avatars" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/space_md"
                android:layout_marginEnd="@dimen/space_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_cmt_user_name"
                        style="@style/TextAppearance.UpAgain.BodyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textColor="@color/color_on_background"
                        tools:text="Jack Collins" />

                    <TextView
                        android:id="@+id/tv_cmt_time"
                        style="@style/TextAppearance.UpAgain.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:textColor="@color/color_secondary"
                        tools:text="12:23:56 - June 4 2026" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_cmt_content"
                    style="@style/TextAppearance.UpAgain.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/color_on_background"
                    tools:text="This is an awesome analysis! Thanks for breaking down the architectural models." />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cmt_like"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="@dimen/min_touch"
                android:layout_height="@dimen/min_touch"
                app:icon="@drawable/ic_love_outline"
                app:iconSize="@dimen/icon_sm"
                app:iconTint="@color/red" />

            <TextView
                android:id="@+id/tv_cmt_like_nb"
                style="@style/TextAppearance.UpAgain.BodySmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_secondary"
                tools:text="14" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_outline"
        android:alpha="0.15"
        android:layout_marginTop="@dimen/space_sm"
        app:layout_constraintTop_toBottomOf="@id/layout_comment_row_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>