<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_background"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md">

            <TextView
                android:id="@+id/tv_title"
                style="@style/TextAppearance.UpAgain.H1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_md"
                android:text="@string/container"
                android:textColor="@color/color_on_background"
                app:layout_constraintEnd_toStartOf="@+id/iv_deco"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_deco"
                android:layout_width="@dimen/icon_lg"
                android:layout_height="@dimen/icon_lg"
                android:src="@drawable/ic_container"
                app:layout_constraintBottom_toBottomOf="@+id/tv_title"
                app:tint="@color/color_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tv_title" />

            <TextView
                android:id="@+id/tv_description"
                style="@style/TextAppearance.UpAgain.BodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:alpha="0.8"
                android:text="@string/container_desc"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_deco" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <TextView
                style="@style/TextAppearance.UpAgain.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/container_id" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_container_id"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                app:boxCornerRadiusBottomEnd="@dimen/input_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_radius"
                app:boxCornerRadiusTopStart="@dimen/input_radius"
                app:errorEnabled="false"
                app:errorTextAppearance="@style/TextAppearance.Material3.BodySmall"
                app:errorTextColor="@color/color_error"
                app:errorIconTint="@color/color_error">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_container_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:inputType="number"
                    android:letterSpacing="0.5"
                    style="@style/TextAppearance.UpAgain.H2" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/TextAppearance.UpAgain.H3"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/code" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_code"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                app:boxCornerRadiusBottomEnd="@dimen/input_radius"
                app:boxCornerRadiusBottomStart="@dimen/input_radius"
                app:boxCornerRadiusTopEnd="@dimen/input_radius"
                app:boxCornerRadiusTopStart="@dimen/input_radius"
                app:errorEnabled="false"
                app:errorTextAppearance="@style/TextAppearance.Material3.BodySmall"
                app:errorTextColor="@color/color_error"
                app:errorIconTint="@color/color_error">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:inputType="text"
                    android:letterSpacing="0.5"
                    android:maxLength="6"
                    style="@style/TextAppearance.UpAgain.H2" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/TextAppearance.UpAgain.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/barcode" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_upload_zone"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="@dimen/space_sm"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="@dimen/card_radius"
                app:strokeColor="@color/color_outline"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:id="@+id/layout_upload_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/input_round"
                    android:backgroundTint="@color/color_surface"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_upload_thumbnail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/layout_upload_prompt"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <ImageView
                            android:layout_width="@dimen/icon_lg"
                            android:layout_height="@dimen/icon_lg"
                            android:src="@drawable/ic_upload"
                            app:tint="@color/color_primary" />

                        <TextView
                            style="@style/TextAppearance.UpAgain.BodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/barcode_upload_hint"
                            android:textColor="@color/color_on_background"
                            android:gravity="center" />
                    </LinearLayout>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/btn_clear_upload"
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:layout_gravity="top|end"
                        android:layout_margin="@dimen/space_sm"
                        android:padding="@dimen/space_xs"
                        android:src="@drawable/ic_trash"
                        android:background="@color/color_surface"
                        android:elevation="@dimen/space_xs"
                        android:clickable="true"
                        android:focusable="true"
                        android:backgroundTint="@color/color_surface"
                        android:foreground="?attr/selectableItemBackground"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="@color/color_error"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/upload_zone_loader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        app:indicatorSize="32dp"
                        app:trackThickness="3dp"
                        app:indicatorColor="@color/color_primary"
                        android:visibility="gone" />

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/input_round"
                android:backgroundTint="@color/color_background"
                android:orientation="horizontal"
                android:padding="@dimen/space_md">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_info"
                    app:tint="@color/color_secondary" />

                <TextView
                    style="@style/TextAppearance.UpAgain.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="@string/container_how_to"
                    android:textColor="@color/color_secondary" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/min_touch"
                    android:text="@string/btn_open_container"
                    android:textAllCaps="true"
                    app:cornerRadius="@dimen/button_radius"
                    app:backgroundTint="@color/color_primary" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/submit_loader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    app:indicatorSize="@dimen/icon_md"
                    app:indicatorColor="@color/color_on_primary"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>