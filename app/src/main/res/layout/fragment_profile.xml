<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_background"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_md">

            <TextView
                android:id="@+id/tv_shop_title"
                style="@style/TextAppearance.Material3.HeadlineMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:textColor="@color/color_on_background"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btn_logout"
                android:layout_width="@dimen/min_touch"
                android:layout_height="@dimen/min_touch"
                android:padding="@dimen/space_sm"
                android:src="@drawable/ic_logout"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/color_error" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_xxl">

            <!-- HEADER SECTION: AVATAR & NAME -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_xl">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    tools:src="@tools:sample/avatars"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="@color/color_primary"
                    app:strokeWidth="3dp" />

                <TextView
                    android:id="@+id/tv_username"
                    style="@style/TextAppearance.UpAgain.H2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:text="Sarah Jenkins"
                    android:textColor="@color/color_on_background" />

                <TextView
                    android:id="@+id/tv_role"
                    style="@style/TextAppearance.UpAgain.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Professional"
                    android:textColor="@color/color_primary" />
            </LinearLayout>

            <!-- SUBSCRIPTION CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_xl"
                app:cardBackgroundColor="@color/color_secondary"
                app:cardCornerRadius="@dimen/card_radius"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:id="@+id/tv_plan_label"
                        style="@style/TextAppearance.UpAgain.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/current_plan"
                        android:textColor="@color/color_on_secondary"
                        android:alpha="0.7"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_plan_type"
                        style="@style/TextAppearance.UpAgain.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_accent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_plan_label"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_plan_expiry"
                        style="@style/TextAppearance.UpAgain.BodySmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/expire_date"
                        android:textColor="@color/color_on_secondary"
                        app:layout_constraintTop_toBottomOf="@+id/tv_plan_type"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ACCOUNT INFORMATION -->
            <TextView
                style="@style/TextAppearance.UpAgain.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/account_information" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:background="@drawable/input_round"
                android:backgroundTint="@color/color_surface"
                android:orientation="vertical"
                android:padding="@dimen/space_md">

                <!-- Field: Username -->
                <TextView
                    style="@style/TextAppearance.UpAgain.BodySmall"
                    android:text="@string/username" android:alpha="0.6" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/et_profile_name"
                    style="@style/TextAppearance.UpAgain.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:text="Sarah Jenkins"
                    android:paddingVertical="@dimen/space_xs"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_background"
                    android:layout_marginVertical="@dimen/space_sm"/>

                <!-- Field: Email -->
                <TextView
                    style="@style/TextAppearance.UpAgain.BodySmall"
                    android:text="@string/email"
                    android:alpha="0.6"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText
                    android:id="@+id/et_profile_email"
                    style="@style/TextAppearance.UpAgain.BodyMedium"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:text="sarah.j@example.com" android:paddingVertical="@dimen/space_xs"/>

                <View android:layout_width="match_parent"
                    android:layout_height="1dp" android:background="@color/color_background" android:layout_marginVertical="@dimen/space_sm"/>

                <!-- Field: Phone -->
                <TextView
                    style="@style/TextAppearance.UpAgain.BodySmall"
                    android:text="@string/phone"
                    android:alpha="0.6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <EditText android:id="@+id/et_profile_phone" style="@style/TextAppearance.UpAgain.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:text="+1 234 567 890" android:paddingVertical="@dimen/space_xs"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_background" android:layout_marginVertical="@dimen/space_sm"/>

                <!-- Field: Join Date (ReadOnly style) -->
                <TextView
                    style="@style/TextAppearance.UpAgain.BodySmall"
                    android:text="@string/member_since" android:alpha="0.6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    style="@style/TextAppearance.UpAgain.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jan 2024"
                    android:paddingVertical="@dimen/space_xs"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_profile"
                style="@style/Widget.Material3.Button"
                android:textColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/btn_save"
                app:cornerRadius="@dimen/button_radius" />

            <!-- SETTINGS SECTION -->
            <TextView
                style="@style/TextAppearance.UpAgain.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="Settings" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:background="@drawable/input_round"
                android:backgroundTint="@color/color_surface"
                android:orientation="vertical">

                <!-- Row: Security -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_setting_security"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/min_touch"
                    android:paddingHorizontal="@dimen/space_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        style="@style/TextAppearance.UpAgain.BodyLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/color_secondary" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="@dimen/space_md"
                    android:background="@color/color_background" />

                <!-- Row: Security -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_setting_noti"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/min_touch"
                    android:paddingHorizontal="@dimen/space_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        style="@style/TextAppearance.UpAgain.BodyLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notification"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/color_secondary" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="@dimen/space_md"
                    android:background="@color/color_background" />

                <!-- Row: Delete Account -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_setting_delete"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/min_touch"
                    android:paddingHorizontal="@dimen/space_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        style="@style/TextAppearance.UpAgain.BodyLarge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete_account"
                        android:textColor="@color/color_error"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_trash"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/color_error" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>