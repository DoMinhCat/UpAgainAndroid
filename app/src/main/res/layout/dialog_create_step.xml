<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_xl"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_lg">

        <!-- Title Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_step_title"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            android:hint="@string/step_title">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textAutoCorrect|textCapSentences"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description Field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_step_desc"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            android:hint="@string/step_description">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_step_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:minLines="5" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Items Section -->
        <TextView
            style="@style/TextAppearance.UpAgain.H3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xs"
            android:text="@string/associated_items"
            android:textColor="@color/color_on_background" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_select_items"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xs"
            android:hint="@string/select_items">

            <AutoCompleteTextView
                android:id="@+id/actv_select_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/color_on_background" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_selected_items_summary"
            style="@style/TextAppearance.UpAgain.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            android:textColor="@color/color_primary"
            android:text="@string/none_selected" />

        <!-- Images Section -->
        <TextView
            style="@style/TextAppearance.UpAgain.H3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_sm"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/images"
            android:textColor="@color/color_on_background" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="@dimen/card_radius"
            app:strokeColor="@color/color_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_step_upload_prompt"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_upload"
                        app:tint="@color/color_primary" />

                    <TextView
                        style="@style/TextAppearance.UpAgain.BodyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center"
                        android:text="@string/image_upload_hint"
                        android:textColor="@color/color_on_background" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_step_chosen_images"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
